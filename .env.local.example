NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_PROGRAM_ID=
# When false (default), flags and votes are recorded locally with a deterministic
# "would-be" signature — no SOL needed, instant submit. When true, every flag and
# vote sends a real signed transaction to Solana devnet via the SPL Memo program
# (requires the connected wallet to have ~0.000005 SOL per tx).
NEXT_PUBLIC_ONCHAIN_MODE=false
