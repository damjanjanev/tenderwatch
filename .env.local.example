NEXT_PUBLIC_SOLANA_NETWORK=devnet
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com
NEXT_PUBLIC_PROGRAM_ID=

# false = flags/votes are simulated locally (no SOL needed, instant submit)
# true  = real SPL Memo transactions on Solana devnet (~0.000005 SOL per tx)
NEXT_PUBLIC_ONCHAIN_MODE=false

# true  = any connected wallet can act as a verifier (for demo/testing)
# false = only wallets in VERIFIER_ALLOWLIST in lib/store.ts can verify
NEXT_PUBLIC_DEMO_MODE=true
